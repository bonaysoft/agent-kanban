{
  "name": "@agent-kanban/web",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "B=$(awk 'NF{printf \"-b %s \", $0}' .dev.vars) && wrangler pages dev --compatibility-flags nodejs_compat $B -- vite",
    "build": "vite build",
    "preview": "wrangler pages dev dist",
    "db:migrate": "wrangler d1 migrations apply agent-kanban-db --local",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@agent-kanban/shared": "workspace:*",
    "@better-auth/agent-auth": "^0.4.0",
    "@better-auth/api-key": "^1.5.5",
    "better-auth": "^1.5.5",
    "hono": "^4.7.0",
    "kysely": "^0.28.14",
    "kysely-d1": "^0.4.0",
    "nanoid": "^5.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250313.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "wrangler": "^4.76.0"
  }
}
