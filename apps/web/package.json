{
  "name": "@agent-kanban/web",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "mkdir -p .pages-dev && B=$(awk 'NF{printf \"-b %s \", $0}' .dev.vars) && concurrently -n relay,vite,wrangler -c yellow,blue,green \"wrangler dev --config ../../packages/relay-worker/wrangler.toml --port 8787\" \"vite\" \"sleep 3 && wrangler pages dev .pages-dev $B\"",
    "build": "vite build",
    "preview": "wrangler pages dev dist",
    "db:migrate": "wrangler d1 migrations apply agent-kanban-db --local",
    "db:reset": "rm -rf .wrangler/state && pnpm db:migrate",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@agent-kanban/shared": "workspace:*",
    "@assistant-ui/react": "^0.12.21",
    "@assistant-ui/react-markdown": "^0.12.7",
    "@base-ui/react": "^1.3.0",
    "@better-auth/agent-auth": "^0.4.0",
    "@better-auth/api-key": "^1.5.5",
    "@fontsource-variable/geist": "^5.2.8",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-dialog": "^1.1.15",
    "@tanstack/react-query": "^5.95.2",
    "better-auth": "^1.5.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.20",
    "highlight.js": "^11.11.1",
    "hono": "^4.7.0",
    "kysely": "^0.28.14",
    "kysely-d1": "^0.4.0",
    "lucide-react": "^0.577.0",
    "nanoid": "^5.0.0",
    "openpgp": "^6.3.0",
    "radix-ui": "^1.4.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.0.0",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "shadcn": "^4.1.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "tw-shimmer": "^0.4.9",
    "vaul": "^1.1.2",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250313.0",
    "@tailwindcss/vite": "^4.2.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.7.0",
    "vite": "^6.4.2",
    "wrangler": "^4.76.0"
  }
}
